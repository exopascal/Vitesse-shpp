# Multi-Tenant Configuration
TENANT_ID=default

# Shopify Configuration
SHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2023-10
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token

# Cloudflare Cache Invalidation (optional)
